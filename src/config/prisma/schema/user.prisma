enum Role {
  PARENT
  TUTOR
}

model User { 
  id        Int      @id @default(autoincrement())
  uid       String   @unique @default(uuid())
  username  String   @unique
  email     String   @unique
  password  String   // Hashed password
  name      String
  role      Role     @default(TUTOR)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
