NODE_ENV=development
PORT=8000

# Connect to Postgres via the shared transaction-mode pooler (IPv4-only)
DATABASE_URL="postgresql://[user]:[password]@[host]:6543/[db]?pgbouncer=true"

# Connect to Postgres via the shared session-mode pooler (used for migrations)
DIRECT_URL="postgresql://[user]:[password]@[host]:5432/[db]"

# JWT Token Settings
JWT_SECRET="your-super-secure-jwt-signature-key-secret"
JWT_EXPIRES_IN="24h"

# CORS Origin Settings (comma-separated list of origins, e.g. http://localhost:3000,https://tuition-workspace.vercel.app)
CORS_ORIGIN="*"

# Maximum File Upload Size in bytes (e.g. 5242880 = 5MB)
MAX_FILE_SIZE=5242880
